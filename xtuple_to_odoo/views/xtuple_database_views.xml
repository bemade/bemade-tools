<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_xtuple_database_form" model="ir.ui.view">
        <field name="name">xtuple.database.form</field>
        <field name="model">xtuple.database</field>
        <field name="arch" type="xml">
            <form string="xTuple Database">
                <header>
                    <button name="action_import_all" 
                            string="Import All" 
                            type="object" 
                            class="btn-primary"
                            icon="fa-download"/>
                    <button name="action_import_partners" 
                            string="Import Partners" 
                            type="object"
                            icon="fa-users"/>
                    <button name="action_import_products" 
                            string="Import Products" 
                            type="object"
                            icon="fa-cube"/>
                    <button name="action_import_boms" 
                            string="Import BOMs" 
                            type="object"
                            icon="fa-sitemap"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Connection">
                            <field name="database_host" placeholder="e.g. 192.168.1.100"/>
                            <field name="database_port"/>
                            <field name="database_name" placeholder="e.g. xtuple_prod"/>
                            <field name="database_schema" placeholder="e.g. public"/>
                        </group>
                        <group string="Authentication">
                            <field name="database_username"/>
                            <field name="database_password" password="True"/>
                        </group>
                    </group>
                    <group string="Optional">
                        <field name="filestore_path" placeholder="/path/to/xtuple/filestore"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_xtuple_database_list" model="ir.ui.view">
        <field name="name">xtuple.database.list</field>
        <field name="model">xtuple.database</field>
        <field name="arch" type="xml">
            <list string="xTuple Databases">
                <field name="database_host"/>
                <field name="database_name"/>
                <field name="database_port"/>
                <field name="database_schema"/>
                <field name="database_username"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_xtuple_database" model="ir.actions.act_window">
        <field name="name">xTuple Database</field>
        <field name="res_model">xtuple.database</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure your xTuple database connection
            </p>
            <p>
                Enter your xTuple PostgreSQL database connection details to import data into Odoo.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_xtuple_root"
              name="xTuple Import"
              sequence="100"/>

    <menuitem id="menu_xtuple_config"
              name="Configuration"
              parent="menu_xtuple_root"
              sequence="10"/>

    <menuitem id="menu_xtuple_database"
              name="Database Connection"
              parent="menu_xtuple_config"
              action="action_xtuple_database"
              sequence="10"/>
</odoo>
