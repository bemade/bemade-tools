<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- Report form -->
    <record id="qbo_migration_report_view_form" model="ir.ui.view">
        <field name="name">qbo.migration.report.form</field>
        <field name="model">qbo.migration.report</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_run" type="object"
                            string="Run Validation" class="btn-primary"/>
                    <button name="action_create_opening_balance" type="object"
                            string="Create Opening Balance JE" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="qbo_connection_id"/>
                            <field name="tolerance"/>
                            <field name="opening_balance_account_id"/>
                        </group>
                        <group>
                            <field name="match_count"/>
                            <field name="drift_count"/>
                            <field name="qbo_only_count"/>
                            <field name="odoo_only_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trial Balance" name="tb">
                            <field name="tb_line_ids" nolabel="1">
                                <list decoration-danger="status == 'drift'"
                                      decoration-warning="status in ('qbo_only', 'odoo_only')"
                                      decoration-success="status == 'match'">
                                    <field name="status" optional="show"/>
                                    <field name="account_code"/>
                                    <field name="qbo_acct_name"/>
                                    <field name="odoo_acct_name" optional="hide"/>
                                    <field name="qbo_debit" sum="QBO Debit"/>
                                    <field name="qbo_credit" sum="QBO Credit"/>
                                    <field name="qbo_balance" sum="QBO Balance"/>
                                    <field name="odoo_debit" sum="Odoo Debit"/>
                                    <field name="odoo_credit" sum="Odoo Credit"/>
                                    <field name="odoo_balance" sum="Odoo Balance"/>
                                    <field name="balance_diff" sum="Difference"/>
                                </list>
                            </field>
                        </page>
                        <page string="Transaction Detail" name="txn">
                            <field name="txn_line_ids" nolabel="1">
                                <list decoration-danger="source == 'qbo'"
                                      decoration-info="source == 'odoo'">
                                    <field name="source"/>
                                    <field name="account_code"/>
                                    <field name="date"/>
                                    <field name="memo"/>
                                    <field name="partner_name" optional="show"/>
                                    <field name="qbo_id" optional="show"/>
                                    <field name="qbo_type" optional="show"/>
                                    <field name="qbo_debit" sum="QBO Debit"/>
                                    <field name="qbo_credit" sum="QBO Credit"/>
                                    <field name="odoo_move_name" optional="show"/>
                                    <field name="odoo_ref" optional="show"/>
                                    <field name="odoo_debit" sum="Odoo Debit"/>
                                    <field name="odoo_credit" sum="Odoo Credit"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Report list -->
    <record id="qbo_migration_report_view_list" model="ir.ui.view">
        <field name="name">qbo.migration.report.list</field>
        <field name="model">qbo.migration.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="match_count"/>
                <field name="drift_count"/>
                <field name="qbo_only_count"/>
                <field name="odoo_only_count"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="qbo_migration_report_action" model="ir.actions.act_window">
        <field name="name">Migration Reports</field>
        <field name="res_model">qbo.migration.report</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu under QBO -->
    <menuitem id="qbo_menu_migration_report"
              name="Migration Reports"
              parent="qbo_menu_root"
              action="qbo_migration_report_action"
              sequence="90"/>

</odoo>
