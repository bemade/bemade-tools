<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add sap_comment to BOM line list view (embedded in BOM form) -->
    <record id="view_mrp_bom_form_sap_comment" model="ir.ui.view">
        <field name="name">mrp.bom.form.sap.comment</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='bom_line_ids']//list//field[@name='product_qty']" position="after">
                <field name="sap_comment" optional="show" string="SAP Comment"/>
            </xpath>
        </field>
    </record>

    <!-- Add sap_comment to production order components list (move_raw_ids) -->
    <record id="view_mrp_production_form_sap_comment" model="ir.ui.view">
        <field name="name">mrp.production.form.sap.comment</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_raw_ids']//list//field[@name='bom_line_id']" position="after">
                <field name="sap_comment" optional="show" string="SAP Comment"/>
            </xpath>
        </field>
    </record>
</odoo>
