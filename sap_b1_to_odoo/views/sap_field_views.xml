<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_partner_tree_sap_inherit" model="ir.ui.view">
        <field name="name">res.partner.tree.sap.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <field name="complete_name" position="before">
                <field name="sap_card_code" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_partner_search_sap_inherit" model="ir.ui.view">
        <field name="name">res.partner.search.sap.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="sap_card_code" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_sale_order_tree_sap_inherit" model="ir.ui.view">
        <field name="name">sale.order.tree.sap.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="sap_docnum" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_sale_order_search_sap_inherit" model="ir.ui.view">
        <field name="name">sale.order.search.sap.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="sap_docnum" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_sale_order_form_sap_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.sap.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="sap_docnum" readonly="1" invisible="not sap_docnum"/>
            </field>
        </field>
    </record>

    <record id="view_product_product_tree_sap_inherit" model="ir.ui.view">
        <field name="name">product.product.tree.sap.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="default_code" position="after">
                <field name="sap_item_code" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_product_product_search_sap_inherit" model="ir.ui.view">
        <field name="name">product.product.search.sap.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <field name="product_tag_ids" position="before">
                <field name="sap_item_code"/>
            </field>
        </field>
    </record>

    <record id="view_product_product_stock_search_sap_inherit" model="ir.ui.view">
        <field name="name">product.product.stock.search.sap.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.stock_product_search_form_view"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="sap_item_code"/>
            </field>
        </field>
    </record>

    <record id="view_purchase_order_view_list_sap_inherit" model="ir.ui.view">
        <field name="name">purchase.order.view.list.sap.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="sap_docnum" optional="show"/>
            </field>
        </field>
    </record>
    <record id="view_purchase_order_kpis_tree_sap_inherit" model="ir.ui.view">
        <field name="name">purchase.order.kpis.tree.sap.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="sap_docnum" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_purchase_order_search_sap_inherit" model="ir.ui.view">
        <field name="name">purchase.order.search.sap.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="before">
                <field name="sap_docnum"/>
            </field>
        </field>
    </record>

    <record id="view_purchase_order_form_sap_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.sap.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="sap_docnum" readonly="1" invisible="not sap_docnum"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_form_sap_inherit" model="ir.ui.view">
        <field name="name">account.move.form.sap.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_right_group']" position="inside">
                <label for="sap_docnum" string="SAP Document" style="font-weight:bold;" invisible="not sap_docnum"/>
                <field name="sap_docnum" nolabel="1" readonly="1" invisible="not sap_docnum"/>
            </xpath>
        </field>
    </record>

</odoo>