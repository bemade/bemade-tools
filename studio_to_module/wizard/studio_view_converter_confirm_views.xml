<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_studio_view_converter_confirm_form" model="ir.ui.view">
            <field name="name">studio.view.converter.confirm.form</field>
            <field name="model">studio.view.converter.confirm</field>
            <field name="arch" type="xml">
                <form string="Conversion Successful">
                    <sheet>
                        <div class="alert alert-success" role="alert">
                            <h3>✅ Studio Views Successfully Converted!</h3>
                        </div>
                        
                        <group>
                            <field name="message" widget="text" nolabel="1" readonly="1"/>
                        </group>
                        
                        <group>
                            <field name="target_module_id" invisible="1"/>
                            <field name="converted_view_count" invisible="1"/>
                        </group>
                        
                        <div class="alert alert-info" role="alert">
                            <p><strong>Would you like to upgrade the module now?</strong></p>
                            <p>Upgrading the module will:</p>
                            <ul>
                                <li>Apply the converted views to your database</li>
                                <li>Automatically delete the Studio views (if auto cleanup is enabled)</li>
                            </ul>
                        </div>
                    </sheet>
                    <footer>
                        <button name="action_upgrade_and_cleanup" 
                                string="Upgrade + Cleanup Now (DEV)" 
                                type="object" 
                                class="btn-primary"
                                help="Upgrade module and run cleanup hook without restarting (DEV mode only)"/>
                        <button name="action_upgrade_module" 
                                string="Upgrade Module (Restart Required)" 
                                type="object" 
                                class="btn-secondary"
                                help="Standard upgrade - requires Odoo restart before running"/>
                        <button name="action_close" 
                                string="Close (Upgrade Later)" 
                                type="object" 
                                class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
